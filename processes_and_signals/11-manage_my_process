#!/usr/bin/env bash
# Manages the manage_my_process script

if [ "$#" -lt 1 ]; then
    echo "Usage: manage_my_process {start|stop|restart}"
    exit 1
fi

ACTION=$1
PID_FILE="/var/run/my_process.pid"

case "$ACTION" in
    start)
        ./manage_my_process &
        echo $! > "$PID_FILE" 2>/dev/null || echo $! > my_process.pid
        echo "manage_my_process started"
        ;;
    stop)
        P_ID=$(cat "$PID_FILE" 2>/dev/null || cat my_process.pid 2>/dev/null)
        if [ -n "$P_ID" ]; then
            kill "$P_ID"
            rm -f "$PID_FILE" my_process.pid
            echo "manage_my_process stopped"
        fi
        ;;
    restart)
        # Stop
        P_ID=$(cat "$PID_FILE" 2>/dev/null || cat my_process.pid 2>/dev/null)
        [ -n "$P_ID" ] && kill "$P_ID"
        rm -f "$PID_FILE" my_process.pid
        # Start
        ./manage_my_process &
        echo $! > "$PID_FILE" 2>/dev/null || echo $! > my_process.pid
        echo "manage_my_process restarted"
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        ;;
esac
