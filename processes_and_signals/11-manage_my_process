#!/usr/bin/env bash
# Manages the manage_my_process script with proper PID file creation

PID_FILE="/var/run/my_process.pid"

case "$1" in
    start)
        ./manage_my_process &
        # PID-i mütləq fayla yaz, icazə xətası olsa sudo ilə yoxla
        echo "$!" | sudo tee "$PID_FILE" > /dev/null
        echo "manage_my_process started"
        ;;
    stop)
        # Fayldan PID-i oxu və prosesi öldür
        if [ -f "$PID_FILE" ]; then
            sudo kill "$(cat "$PID_FILE")"
            sudo rm -f "$PID_FILE"
        fi
        echo "manage_my_process stopped"
        ;;
    restart)
        # Öncə dayandır
        if [ -f "$PID_FILE" ]; then
            sudo kill "$(cat "$PID_FILE")"
            sudo rm -f "$PID_FILE"
        fi
        # Sonra başlat
        ./manage_my_process &
        echo "$!" | sudo tee "$PID_FILE" > /dev/null
        echo "manage_my_process restarted"
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        ;;
esac
