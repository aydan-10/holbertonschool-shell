#!/usr/bin/env bash
# Manages manage_my_process init script

PIDFILE="/var/run/my_process.pid"

if [ "$1" = "start" ]; then
    ./manage_my_process &
    echo $! > "$PIDFILE" 2>/dev/null || echo $! > /tmp/my_process.pid
    echo "manage_my_process started"
elif [ "$1" = "stop" ]; then
    kill "$(cat "$PIDFILE" 2>/dev/null || cat /tmp/my_process.pid)"
    rm -f "$PIDFILE" /tmp/my_process.pid
    echo "manage_my_process stopped"
elif [ "$1" = "restart" ]; then
    kill "$(cat "$PIDFILE" 2>/dev/null || cat /tmp/my_process.pid)"
    rm -f "$PIDFILE" /tmp/my_process.pid
    ./manage_my_process &
    echo $! > "$PIDFILE" 2>/dev/null || echo $! > /tmp/my_process.pid
    echo "manage_my_process restarted"
else
    echo "Usage: manage_my_process {start|stop|restart}"
fi
