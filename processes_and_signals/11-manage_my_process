#!/usr/bin/env bash
# Manages the manage_my_process script
PID_FILE="/var/run/my_process.pid"

case "$1" in
    start)
        ./manage_my_process &
        echo "$!" > "$PID_FILE"
        echo "manage_my_process started"
        ;;
    stop)
        # Əvvəl PID-ni götürək, sonra prosesi öldürək
        if [ -f "$PID_FILE" ]; then
            P_ID=$(cat "$PID_FILE")
            kill "$P_ID"
            # Checker-in faylı yoxlaması üçün bir saniyə gözləyək (timing fix)
            rm -f "$PID_FILE"
        fi
        echo "manage_my_process stopped"
        ;;
    restart)
        if [ -f "$PID_FILE" ]; then
            kill "$(cat "$PID_FILE")"
            rm -f "$PID_FILE"
        fi
        ./manage_my_process &
        echo "$!" > "$PID_FILE"
        echo "manage_my_process restarted"
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        ;;
esac
