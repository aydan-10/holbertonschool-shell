#!/usr/bin/env bash
# Creates a PID file and handles SIGINT and SIGTERM
PID_FILE="/var/run/myscript.pid"

# PID-i fayla yaz (icazə xətası olsa belə mütləq cəhd etsin)
echo $$ | sudo tee "$PID_FILE" > /dev/null

# SIGINT trap
trap 'echo "Y U no love me?!"' SIGINT

# SIGTERM trap
trap 'echo "I hate the kill command"; sudo rm -f "$PID_FILE"; exit' SIGTERM

# SIGQUIT trap
trap 'sudo rm -f "$PID_FILE"; exit' SIGQUIT

while true
do
    echo "To infinity and beyond"
    sleep 2
done
